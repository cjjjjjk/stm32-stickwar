# Default: normalize line endings to LF in repo
* text=auto eol=lf

# Makefiles must be LF — CRLF breaks make on Linux
Makefile text eol=lf
*.mk text eol=lf

# C/C++ source files
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.s text eol=lf

# Scripts
*.sh text eol=lf
*.py text eol=lf
*.rb text eol=lf

# Linker scripts
*.ld text eol=lf

# GitHub Actions
*.yml text eol=lf
*.yaml text eol=lf

# Binary files — do not touch line endings
*.png binary
*.bmp binary
*.ttf binary
*.otf binary
*.bin binary
*.elf binary
*.hex binary
*.a binary
*.o binary
*.out binary
